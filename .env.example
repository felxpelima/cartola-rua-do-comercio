# DATABASE_URL é injetado AUTOMATICAMENTE pela integração Prisma Postgres
# (Vercel > Storage > Connect Database > Prisma). Você não precisa colá-lo aqui.
#
# Para rodar comandos locais (ex.: prisma db push), puxe as variáveis com:
#   npx vercel env pull .env
DATABASE_URL="postgres://...(vem da integração)..."

# Senha que você digita no painel /admin
ADMIN_PASSWORD=troque_esta_senha

# Segredo para assinar o login. Gere algo longo, ex.: openssl rand -base64 32
JWT_SECRET=cadeia_longa_aleatoria_aqui

# Segredo opcional para disparar /api/sync-cartola via cron externo.
# Use como header x-cron-secret ou query ?secret=...
CRON_SECRET=outro_segredo_longo_para_rotina
